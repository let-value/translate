{
    "name": "@let-value/translate-extract-static",
    "version": "1.1.6-beta.1",
    "repository": {
        "type": "git",
        "url": "https://github.com/let-value/translate"
    },
    "bin": {
        "extract": "./dist/bin/cli.mjs"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "main": "./dist/src/index.cjs",
    "module": "./dist/src/index.mjs",
    "types": "./dist/src/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/src/index.d.mts",
            "import": "./dist/src/index.mjs",
            "require": "./dist/src/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "vp pack",
        "compile": "bun run scripts/compile.ts",
        "check": "vp check",
        "format": "vp fmt",
        "typecheck": "tsc --build",
        "test": "vp test"
    },
    "dependencies": {
        "detect-libc": "2.1.2"
    },
    "devDependencies": {
        "@let-value/translate": "workspace:*",
        "@let-value/translate-extract": "workspace:*",
        "@types/bun": "1.3.14",
        "@types/node": "26.1.0",
        "typescript": "6.0.3",
        "vite-plus": "latest"
    },
    "optionalDependencies": {
        "@let-value/translate-extract-static-darwin-arm64": "workspace:*",
        "@let-value/translate-extract-static-darwin-x64": "workspace:*",
        "@let-value/translate-extract-static-linux-arm64-gnu": "workspace:*",
        "@let-value/translate-extract-static-linux-arm64-musl": "workspace:*",
        "@let-value/translate-extract-static-linux-x64-gnu": "workspace:*",
        "@let-value/translate-extract-static-linux-x64-musl": "workspace:*",
        "@let-value/translate-extract-static-win32-x64": "workspace:*"
    }
}
