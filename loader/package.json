{
    "name": "@let-value/translate-loader",
    "version": "1.1.6-beta.1",
    "keywords": [
        "unplugin"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/let-value/translate"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./bun": {
            "types": "./dist/bun.d.mts",
            "import": "./dist/bun.mjs",
            "require": "./dist/bun.cjs"
        },
        "./rollup": {
            "types": "./dist/rollup.d.mts",
            "import": "./dist/rollup.mjs",
            "require": "./dist/rollup.cjs"
        },
        "./vite": {
            "types": "./dist/vite.d.mts",
            "import": "./dist/vite.mjs",
            "require": "./dist/vite.cjs"
        },
        "./webpack": {
            "types": "./dist/webpack.d.mts",
            "import": "./dist/webpack.mjs",
            "require": "./dist/webpack.cjs"
        },
        "./esbuild": {
            "types": "./dist/esbuild.d.mts",
            "import": "./dist/esbuild.mjs",
            "require": "./dist/esbuild.cjs"
        },
        "./rspack": {
            "types": "./dist/rspack.d.mts",
            "import": "./dist/rspack.mjs",
            "require": "./dist/rspack.cjs"
        },
        "./po": {
            "types": "./dist/po.d.ts"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "vp pack && node ./scripts/copy.mjs",
        "check": "vp check",
        "format": "vp fmt",
        "typecheck": "tsc --build",
        "test": "vp test"
    },
    "dependencies": {
        "gettext-parser": "9.1.1",
        "unplugin": "3.3.0"
    },
    "devDependencies": {
        "@types/gettext-parser": "9.0.0",
        "typescript": "6.0.3",
        "vite-plus": "latest"
    },
    "peerDependencies": {
        "@types/bun": "1.2.21"
    }
}
